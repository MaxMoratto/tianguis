# ─────────────────────────────────────────────────────────────
# Firebase (Web App) — cliente
# Firebase console → ⚙️ Configuración del proyecto → Tus apps → SDK setup.
# En Vercel agrégalas en Project → Settings → Environment Variables.
# Mientras estén vacías, la app funciona con datos de ejemplo.
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─────────────────────────────────────────────────────────────
# Stripe (cobros de renta de puesto) — usa primero las llaves de PRUEBA (test)
# Stripe Dashboard → Developers → API keys. Crea 3 precios mensuales y pega sus IDs.
# ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_BASICO=
STRIPE_PRICE_DESTACADO=
STRIPE_PRICE_PREMIUM=

# URL pública del sitio (para los redirects de Checkout). Ej: https://tianguis-gilt.vercel.app
NEXT_PUBLIC_SITE_URL=

# ─────────────────────────────────────────────────────────────
# Firebase Admin (solo servidor) — lo usa el webhook de Stripe para activar el puesto.
# Firebase console → ⚙️ → Cuentas de servicio → Generar nueva clave privada (JSON).
# Copia projectId, client_email y private_key del JSON.
# La private_key va entre comillas y con los \n tal cual (el código los convierte).
# ─────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
