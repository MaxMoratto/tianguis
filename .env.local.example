# Configuración de Firebase (Web App)
# Cópialo como .env.local y pega los valores de tu proyecto.
# Firebase console → ⚙️ Configuración del proyecto → Tus apps → SDK setup and configuration.
#
# En Vercel, agrega estas MISMAS variables en:
# Project → Settings → Environment Variables.
#
# Mientras estén vacías, la app funciona con datos de ejemplo.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
